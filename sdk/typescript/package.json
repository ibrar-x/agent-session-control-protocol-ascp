{
  "name": "ascp-sdk-typescript",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Agent Session & Control Protocol (ASCP).",
  "homepage": "https://github.com/ibrar-x/agent-session-control-protocol-ascp/tree/main/sdk/typescript#readme",
  "bugs": {
    "url": "https://github.com/ibrar-x/agent-session-control-protocol-ascp/issues"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "ascp",
    "agent-session-control-protocol",
    "sdk",
    "typescript",
    "json-rpc",
    "transport",
    "validation",
    "analytics",
    "observability"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ibrar-x/agent-session-control-protocol-ascp.git",
    "directory": "sdk/typescript"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.js"
    },
    "./methods": {
      "types": "./dist/methods/index.d.ts",
      "import": "./dist/methods/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./analytics": {
      "types": "./dist/analytics/index.d.ts",
      "import": "./dist/analytics/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "import": "./dist/transport/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json && node ./scripts/copy-validation-schemas.mjs",
    "test": "vitest run",
    "test:types": "tsc -p tsconfig.type-tests.json",
    "check": "npm run build && npm run test && npm run test:types"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/ws": "^8.18.1",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
