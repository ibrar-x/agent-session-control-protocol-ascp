      "type": "object",
      "required": [
        "session",
        "pending_approvals"
      ],
      "properties": {
        "session": {
          "$ref": "ascp-core.schema.json#/$defs/Session"
        },
        "active_run": {
          "$ref": "ascp-core.schema.json#/$defs/Run"
        },
        "pending_approvals": {
          "type": "array",
          "items": {
            "$ref": "ascp-core.schema.json#/$defs/ApprovalRequest"
          }
        },
        "summary": {
          "$ref": "ascp-core.schema.json#/$defs/FlexibleObject"
        }
      },
