          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "expired_at": {
          "$ref": "ascp-core.schema.json#/$defs/TimestampUtc"
        }
      },
      "additionalProperties": false
    },
    "ArtifactCreatedPayload": {
      "type": "object",
      "required": [
        "artifact"
      ],
      "properties": {
        "artifact": {
          "$ref": "ascp-core.schema.json#/$defs/Artifact"
        }
      },
      "additionalProperties": false
