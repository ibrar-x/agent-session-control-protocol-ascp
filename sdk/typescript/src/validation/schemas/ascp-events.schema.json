{
  "$id": "https://ascp.dev/schema/v0.1/ascp-events.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASCP Event Contracts",
  "description": "Exact EventEnvelope payload contracts for every ASCP core event type.",
  "$defs": {
    "ChangedFields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ConnectionState": {
      "type": "string",
      "enum": [
        "connected",
        "disconnected",
        "reconnecting",
        "reconnected"
      ]
    },
    "Cursor": {
      "type": "string",
      "minLength": 1
    },
    "NonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "PositiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "BaseEvent": {
      "$ref": "ascp-core.schema.json#/$defs/EventEnvelope"
    },
    "SessionCreatedPayload": {
      "type": "object",
      "required": [
        "session"
      ],
      "properties": {
        "session": {
          "$ref": "ascp-core.schema.json#/$defs/Session"
        }
      },
      "additionalProperties": false
    },
    "SessionUpdatedPayload": {
      "type": "object",
      "required": [
        "session",
        "changed_fields"
      ],
      "properties": {
        "session": {
          "type": "object",
          "required": [
            "id",
            "runtime_id",
            "status",
            "updated_at"
          ],
          "properties": {
            "id": {
              "$ref": "ascp-core.schema.json#/$defs/Id"
            },
            "runtime_id": {
              "$ref": "ascp-core.schema.json#/$defs/Id"
            },
            "title": {
              "type": "string"
            },
            "workspace": {
              "type": "string"
            },
            "status": {
              "$ref": "ascp-core.schema.json#/$defs/SessionStatus"
            },
            "created_at": {
              "$ref": "ascp-core.schema.json#/$defs/TimestampUtc"
            },
            "updated_at": {
              "$ref": "ascp-core.schema.json#/$defs/TimestampUtc"
            },
            "last_activity_at": {
              "$ref": "ascp-core.schema.json#/$defs/TimestampUtc"
            },
            "summary": {
              "type": "string"
            },
            "active_run_id": {
              "$ref": "ascp-core.schema.json#/$defs/Id"
            },
            "metadata": {
              "$ref": "ascp-core.schema.json#/$defs/StringMap"
            }
          },
          "additionalProperties": true
        },
        "changed_fields": {
          "$ref": "#/$defs/ChangedFields"
        }
      },
      "additionalProperties": false
    },
    "SessionStatusChangedPayload": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "$ref": "ascp-core.schema.json#/$defs/SessionStatus"
        },
        "to": {
          "$ref": "ascp-core.schema.json#/$defs/SessionStatus"
        }
      },
      "additionalProperties": false
    },
    "SessionDeletedPayload": {
      "type": "object",
      "required": [
        "reason"
      ],
      "properties": {
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "RunStartedPayload": {
      "type": "object",
      "required": [
        "run"
      ],
      "properties": {
        "run": {
          "$ref": "ascp-core.schema.json#/$defs/Run"
