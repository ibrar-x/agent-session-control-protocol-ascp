        "run_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "RunCompletedPayload": {
      "type": "object",
      "required": [
        "run_id",
        "ended_at",
        "exit_code"
      ],
      "properties": {
        "run_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "ended_at": {
          "$ref": "ascp-core.schema.json#/$defs/TimestampUtc"
        },
        "exit_code": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "RunFailedPayload": {
      "type": "object",
      "required": [
        "run_id",
        "ended_at",
        "error_code",
        "message"
      ],
      "properties": {
        "run_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "ended_at": {
          "$ref": "ascp-core.schema.json#/$defs/TimestampUtc"
        },
        "error_code": {
          "$ref": "ascp-errors.schema.json#/$defs/ErrorCode"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "RunCancelledPayload": {
      "type": "object",
      "required": [
        "run_id",
        "ended_at",
        "reason"
      ],
      "properties": {
        "run_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "ended_at": {
          "$ref": "ascp-core.schema.json#/$defs/TimestampUtc"
        },
