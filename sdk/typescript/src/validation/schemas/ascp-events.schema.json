        {
          "$ref": "#/$defs/BaseEvent"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "session.created"
            },
            "payload": {
              "$ref": "#/$defs/SessionCreatedPayload"
            }
          }
        }
      ]
    },
    "SessionUpdatedEvent": {
