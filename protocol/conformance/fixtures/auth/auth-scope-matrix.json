{
  "scopes": {
    "read:capabilities": {
      "access": "read",
      "notes": "Read capability advertisement without implying broader session access."
    },
    "read:hosts": {
      "access": "read",
      "notes": "Read host metadata."
    },
    "read:runtimes": {
      "access": "read",
      "notes": "Read runtime inventory and runtime metadata."
    },
    "read:sessions": {
      "access": "read",
      "notes": "Read session metadata, subscribe to live events, and inspect running state."
    },
    "write:sessions": {
      "access": "control",
      "notes": "Start, resume, stop, or steer interactive sessions."
    },
    "read:approvals": {
      "access": "read",
      "notes": "Read pending and historical approval requests."
    },
    "write:approvals": {
      "access": "control",
      "notes": "Approve or reject pending approvals."
    },
    "read:artifacts": {
      "access": "read",
      "notes": "Read artifact metadata, access information, and diff summaries."
    },
    "admin:host": {
      "access": "admin",
      "notes": "Reserved for host-wide administrative operations or extensions outside the core v0.1 surface."
    }
  },
