        "from_event_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "include_snapshot": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "SessionsUnsubscribeParams": {
      "type": "object",
      "required": [
        "subscription_id"
      ],
      "properties": {
        "subscription_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        }
      },
      "additionalProperties": false
    },
    "ApprovalsListParams": {
      "type": "object",
      "properties": {
        "session_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "status": {
          "$ref": "ascp-core.schema.json#/$defs/ApprovalStatus"
        },
        "limit": {
          "$ref": "#/$defs/Limit"
        },
        "cursor": {
          "$ref": "#/$defs/Cursor"
