    "SessionsSendInputParams": {
      "type": "object",
      "required": [
        "session_id",
        "input"
      ],
      "properties": {
        "session_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "input": {
          "type": "string"
        },
        "input_kind": {
          "$ref": "#/$defs/InputKind"
        },
        "metadata": {
          "$ref": "ascp-core.schema.json#/$defs/FlexibleObject"
        }
      },
      "additionalProperties": false
    },
    "SessionsSubscribeParams": {
      "type": "object",
      "required": [
        "session_id"
      ],
      "properties": {
        "session_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
