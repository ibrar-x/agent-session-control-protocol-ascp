{
  "$id": "https://ascp.dev/schema/v0.1/ascp-methods.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASCP Method Contracts",
  "description": "Exact request, success-response, and method-specific error contracts for the ASCP core method surface.",
  "$defs": {
    "Cursor": {
      "type": "string",
      "minLength": 1
    },
    "NullableCursor": {
      "anyOf": [
        {
          "$ref": "#/$defs/Cursor"
        },
        {
          "type": "null"
        }
      ]
    },
    "Limit": {
      "type": "integer",
      "minimum": 1
    },
    "InputKind": {
      "type": "string",
      "enum": [
        "text",
        "instruction",
        "reply",
        "control"
      ]
    },
    "StopMode": {
      "type": "string",
      "enum": [
        "graceful",
        "force"
      ]
    },
    "ApprovalDecision": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ]
    },
    "ResolvedApprovalStatus": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ]
    },
    "CapabilitiesGetParams": {
      "type": "object",
      "maxProperties": 0,
      "additionalProperties": false
    },
    "HostsGetParams": {
      "type": "object",
      "maxProperties": 0,
      "additionalProperties": false
    },
    "RuntimesListParams": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "adapter_kind": {
          "type": "string",
          "enum": [
            "native",
            "wrapper",
            "pty"
          ]
        }
      },
      "additionalProperties": false
    },
    "SessionsListParams": {
      "type": "object",
      "properties": {
        "runtime_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "status": {
          "$ref": "ascp-core.schema.json#/$defs/SessionStatus"
        },
        "workspace": {
          "type": "string"
        },
        "updated_after": {
          "$ref": "ascp-core.schema.json#/$defs/TimestampUtc"
        },
        "search_text": {
          "type": "string"
        },
        "limit": {
          "$ref": "#/$defs/Limit"
        },
        "cursor": {
          "$ref": "#/$defs/Cursor"
        }
      },
      "additionalProperties": false
    },
    "SessionsGetParams": {
      "type": "object",
      "required": [
        "session_id"
      ],
      "properties": {
        "session_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "include_runs": {
          "type": "boolean"
        },
        "include_pending_approvals": {
          "type": "boolean"
        },
        "include_pending_inputs": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "SessionsStartParams": {
      "type": "object",
      "required": [
        "runtime_id"
      ],
      "properties": {
        "runtime_id": {
          "$ref": "ascp-core.schema.json#/$defs/Id"
        },
        "workspace": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "initial_prompt": {
          "type": "string"
        },
        "metadata": {
          "$ref": "ascp-core.schema.json#/$defs/StringMap"
        }
      },
      "additionalProperties": false
    },
    "SessionsResumeParams": {
      "type": "object",
